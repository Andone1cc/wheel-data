{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "regions": ["hkg1"],
  "rewrites": [
    { "source": "/api/cn-options",     "destination": "/api/data" },
    { "source": "/api/health",          "destination": "/api/data" },
    { "source": "/api/cboe/:ticker",    "destination": "/api/data" },
    { "source": "/api/quote/:ticker",   "destination": "/api/data" },
    { "source": "/api/history/:ticker", "destination": "/api/data" },
    { "source": "/api/futu/:path*",     "destination": "/api/data" },
    { "source": "/(.*)",                "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https: http:; img-src 'self' data: https:;"
        }
      ]
    }
  ]
}
